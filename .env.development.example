# Kopie nach `.env.development` und echte Werte eintragen (Dev-Supabase auf dem VPS).
# Diese Datei ist versioniert; `.env.development` bleibt in .gitignore.
#
# Zweck: Lokales `pnpm dev:dev` gegen eine **eigene** Supabase auf dem VPS —
# ohne Docker Desktop, ohne Live-Daten zu berühren.
# Einrichtung: docs/remote-dev-supabase.md

# Lokaler Next auf http://localhost:3000 → Dev-Kong direkt per HTTP (kein /sb-Proxy nötig)
NEXT_PUBLIC_SUPABASE_PROXY=false
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Kong-Host-Port des 2. Supabase-Stacks auf dem VPS (Coolify, z. B. 8100)
NEXT_PUBLIC_SUPABASE_URL=http://95.111.229.250:8100
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_dev_service_role_key

NEXT_PUBLIC_GWADA_WORKSPACE_SLUG=gwada-demo
NEXT_PUBLIC_GWADA_SUPABASE_ONLY=false

# Postgres für CLI-Migrationen (`pnpm db:push:dev`) — oft per SSH-Tunnel:
# SUPABASE_DB_URL=postgresql://postgres:…@127.0.0.1:5434/postgres
