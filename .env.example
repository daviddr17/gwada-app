# =============================================================================
# Gwada — Umgebungsvariablen (Vorlage)
# =============================================================================
#
# Next.js lädt automatisch je nach NODE_ENV (apps/web/next.config.ts lädt Repo-Root + apps/web):
#
#   Entwicklung (`pnpm dev`):
#     .env.development.local → .env.local → .env.development → .env
#
#   Production (`npm run build` / `npm run start`):
#     .env.production.local → .env.local → .env.production → .env
#
# Empfohlen:
#   • Lokal:  `.env.local` (API :54321, Studio :54323 — siehe `npx supabase status`)
#   • VPS:    API http://HOST:8001, Studio http://HOST:54323, nur `.env.production` auf dem Laptop
#
# Gegen Live-DB vom Laptop testen (ohne .env.local umzubenennen):
#   `npm run dev:live`  (setzt Variablen aus `.env.production` via process.env)
#
# =============================================================================

# --- Supabase (lokal, Standard nach `supabase start`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# --- Supabase (Production — nur in `.env.production`, nicht hier committen) ---
# NEXT_PUBLIC_SUPABASE_URL=http://YOUR_VPS_IP:8001
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# CLI-Migrationen (docs/supabase-lokal-und-live.md) — nicht von Next.js gelesen
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

NEXT_PUBLIC_GWADA_WORKSPACE_SLUG=gwada-demo
# Relational in Postgres (Standard): false — `npm run dev`
NEXT_PUBLIC_GWADA_SUPABASE_ONLY=false
# Nur Supabase, kein localStorage-Fallback: true → `npm run dev:supabase-only`

# Öffentliches Profil: fehlende Felder in `npm run dev` mit Beispieldaten (Social, Kontakt, …).
# Läuft nie auf Production (NODE_ENV). Abschalten: GWADA_LOCAL_PROFILE_PREVIEW=false

# Plattform-Integrationen (Wetter, WAHA, OAuth, SMTP): Secrets nur über Superadmin → Integrationen
# in `platform_integrations` — nicht in .env ablegen (Service-Role, RLS Superadmin-only).
# Optional: Cron für geplante WhatsApp/E-Mail (Erinnerung/Danke)
# CRON_SECRET=

# Changelog Auto-Sync (GitHub Action + npm run changelog:sync)
# CHANGELOG_SYNC_SECRET=generate_a_long_random_string
# CHANGELOG_SYNC_URL=https://YOUR_APP/api/superadmin/changelog/sync-from-git
# Superadmin „Aus Git synchronisieren“ auf Live: GitHub Commits API (kein git im Container).
# CHANGELOG_GIT_REPO=https://github.com/daviddr17/gwada-app.git
# CHANGELOG_GIT_BRANCH=main
# CHANGELOG_GIT_TOKEN=   # nur bei privatem Repo (oder GITHUB_TOKEN)

# Coolify / Live-Deploy (Superadmin → Datenbank, GitHub Actions)
# COOLIFY_API_TOKEN=          # Coolify-UI → Keys → Deployments lesen
# GWADA_COOLIFY_APP_UUID=     # z. B. d3cg1b54arvue2tcm8u34qty
# GWADA_COOLIFY_DASHBOARD_URL=http://VPS:8000
# GITHUB_DEPLOY_TOKEN=        # PAT: repo + workflow (Deploy aus UI + Actions-Status)
# GWADA_GITHUB_REPO=daviddr17/gwada-app
# GWADA_DEPLOY_BRANCH=main
# GitHub Repository Secrets (nicht in .env): LIVE_SSH_KEY, LIVE_VPS_HOST

# --- Google Login (Superadmin → Integrationen → Google OAuth) ---
# App-OAuth-Redirect (Gwada): http://127.0.0.1:3000/api/auth/google/callback  (bzw. NEXT_PUBLIC_SITE_URL)
# Zusätzlich GoTrue (Supabase Auth): dieselbe Client-ID/Secret wie im Superadmin:
#   [auth.external.google] enabled = true in supabase/config.toml
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
#   SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# Hilfe: npm run gotrue:google-env  (liest Client-ID aus lokaler DB)
# Apple Developer → Services ID, Redirect wie in Supabase-Doku
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
# Verlinktes Remote-Projekt: Provider unter Authentication → Providers im Dashboard
