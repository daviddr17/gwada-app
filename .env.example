# =============================================================================
# Gwada — Umgebungsvariablen (Vorlage)
# =============================================================================
#
# Next.js lädt automatisch je nach NODE_ENV (siehe next.config.ts):
#
#   Entwicklung (`npm run dev`):
#     .env.development.local → .env.local → .env.development → .env
#
#   Production (`npm run build` / `npm run start`):
#     .env.production.local → .env.local → .env.production → .env
#
# Empfohlen:
#   • Lokal:  `.env.local` (API :54321, Studio :54323 — siehe `npx supabase status`)
#   • VPS:    API http://HOST:8001, Studio http://HOST:54323, nur `.env.production` auf dem Laptop
#
# Gegen Live-DB vom Laptop testen (ohne .env.local umzubenennen):
#   `npm run dev:live`  (setzt Variablen aus `.env.production` via process.env)
#
# =============================================================================

# --- Supabase (lokal, Standard nach `supabase start`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# --- Supabase (Production — nur in `.env.production`, nicht hier committen) ---
# NEXT_PUBLIC_SUPABASE_URL=http://YOUR_VPS_IP:8001
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# CLI-Migrationen (docs/supabase-lokal-und-live.md) — nicht von Next.js gelesen
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

NEXT_PUBLIC_GWADA_WORKSPACE_SLUG=gwada-demo
# Relational in Postgres (Standard): false — `npm run dev`
NEXT_PUBLIC_GWADA_SUPABASE_ONLY=false
# Nur Supabase, kein localStorage-Fallback: true → `npm run dev:supabase-only`

# Server-only / optional
VISUAL_CROSSING_API_KEY=

# WhatsApp via selbst gehostetes WAHA (https://waha.devlike.pro/) — niemals im Client
# WAHA_BASE_URL=https://waha.gwada.app
# WAHA_API_KEY=
# Optional: Cron für geplante WhatsApp/E-Mail (Erinnerung/Danke)
# CRON_SECRET=

# Reservierungs-E-Mails via n8n (automation.gwada.app, SMTP Send Email Node)
# N8N_RESERVATION_EMAIL_WEBHOOK_URL=https://automation.gwada.app/webhook/gwada-reservation-email
# N8N_WEBHOOK_SECRET=

# --- OAuth (lokal: in supabase/config.toml Provider auf enabled=true setzen) ---
# Google Cloud Console → OAuth-Client (Web), Redirect:
#   http://127.0.0.1:54321/auth/v1/callback
# Apple Developer → Services ID, Redirect wie in Supabase-Doku
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
# Verlinktes Remote-Projekt: Provider unter Authentication → Providers im Dashboard
