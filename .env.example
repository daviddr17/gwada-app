# -----------------------------------------------------------------------------
# Supabase — used by Next.js + `@supabase/ssr`
# -----------------------------------------------------------------------------
# Local API (CLI: `supabase start`): default REST/Auth port is 54321.
# Supabase Studio (Tabellen-UI) läuft separat, z. B. http://localhost:54323 — nicht als NEXT_PUBLIC_SUPABASE_URL setzen.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Restaurant-Slug aus `supabase/seed.sql` / Migrationen — App-State (Menü, Inventar, …) wird diesem Workspace zugeordnet.
NEXT_PUBLIC_GWADA_WORKSPACE_SLUG=gwada-demo

# `true` = nur Supabase (kein localStorage für App-State). Beim Start: blockierender Dialog, wenn die DB nicht erreichbar ist. Für Production meist `false` oder Zeile entfernen.
# Lokal: `npm run dev` setzt dies automatisch auf `true`; für Hybrid (localStorage + DB-Spiegel): `npm run dev:hybrid`.
NEXT_PUBLIC_GWADA_SUPABASE_ONLY=true

# Production (Dashboard → Project Settings → API):
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key

# Server-only: never prefix with NEXT_PUBLIC_. Use only in Route Handlers / server scripts.
# Dashboard → Project Settings → API → service_role (bypasses RLS).
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Other app secrets
# -----------------------------------------------------------------------------
# Visual Crossing Timeline API (Dashboard weather). Set only in `.env.local`.
VISUAL_CROSSING_API_KEY=
