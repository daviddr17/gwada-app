# Kopie nach `.env.production` und echte Werte eintragen (VPS / Cloud-Deploy).
# Domain-Architektur: docs/gwada-app-domains.md

# App per HTTPS, Supabase-API nur HTTP intern: Mixed Content → Proxy (/sb)
NEXT_PUBLIC_SUPABASE_PROXY=true
SUPABASE_UPSTREAM_URL=http://supabase-kong-oogd5syyxiqb1k4g0wy1u9n8:8000
NEXT_PUBLIC_SITE_URL=https://gwada.app
NEXT_PUBLIC_SUPABASE_URL=https://gwada.app/sb
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

NEXT_PUBLIC_GWADA_WORKSPACE_SLUG=gwada-demo
NEXT_PUBLIC_GWADA_SUPABASE_ONLY=false
NEXT_PUBLIC_PASSKEY_ENABLED=true

# Superadmin → Datenbank (Anzeige, optional)
GWADA_PLANNED_PRODUCTION_URL=https://gwada.app
GWADA_LEGACY_BUBBLE_URL=https://old.gwada.app
GWADA_VPS_PUBLIC_HOST=95.111.229.250
GWADA_COOLIFY_DASHBOARD_URL=http://95.111.229.250:8000
GWADA_COOLIFY_APP_UUID=d3cg1b54arvue2tcm8u34qty
# Intern im Docker-Netzwerk coolify (nicht ins Git committen):
# COOLIFY_API_TOKEN=
# GWADA_COOLIFY_API_URL=http://coolify:8080
# Studio: HTTPS über Authelia (Traefik), nicht der rohe Host-Port.
GWADA_SUPABASE_STUDIO_URL=https://studio.new.gwada.app

# Changelog Auto-Sync (GitHub Secrets + gleicher Wert in Coolify)
# CHANGELOG_SYNC_URL=https://gwada.app/api/superadmin/changelog/sync-from-git
# CHANGELOG_SYNC_SECRET=
# Superadmin Git-Sync auf Live: GitHub Commits API (kein git im Container nötig).
# Optional für privates Repo oder höhere Rate-Limits:
# CHANGELOG_GIT_TOKEN=   # oder GITHUB_TOKEN / GITHUB_DEPLOY_TOKEN
# CHANGELOG_GIT_REPO=https://github.com/daviddr17/gwada-app.git
# CHANGELOG_GIT_BRANCH=main

# Docker/Coolify: NEXT_PUBLIC_* beim `docker build` setzen (nicht nur zur Laufzeit).
# Zusätzlich zur Laufzeit: SUPABASE_UPSTREAM_URL, NEXT_PUBLIC_SITE_URL (siehe GwadaPublicEnvScript).
# HTTP-Deploy: createId()-Fallback ist im Code — kein separates Flag nötig.
