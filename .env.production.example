# Kopie nach `.env.production` und echte Werte eintragen (VPS / Cloud-Deploy).
# Diese Datei ist versioniert; `.env.production` bleibt in .gitignore.

# App per HTTPS, Supabase-API nur HTTP: Mixed Content → Proxy nutzen (next.config rewrites /sb)
NEXT_PUBLIC_SUPABASE_PROXY=true
SUPABASE_UPSTREAM_URL=http://YOUR_VPS_IP:8001
NEXT_PUBLIC_SITE_URL=https://YOUR_APP_DOMAIN
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_APP_DOMAIN/sb
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

NEXT_PUBLIC_GWADA_WORKSPACE_SLUG=gwada-demo
NEXT_PUBLIC_GWADA_SUPABASE_ONLY=false

# Docker/Coolify: NEXT_PUBLIC_* beim `docker build` setzen (nicht nur zur Laufzeit).
# Zusätzlich zur Laufzeit: SUPABASE_UPSTREAM_URL, NEXT_PUBLIC_SITE_URL (siehe GwadaPublicEnvScript).
# HTTP-Deploy: createId()-Fallback ist im Code — kein separates Flag nötig.
