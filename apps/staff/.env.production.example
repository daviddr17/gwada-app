EXPO_PUBLIC_GWADA_API_URL=https://gwada.app
EXPO_PUBLIC_SUPABASE_URL=https://gwada.app/sb
EXPO_PUBLIC_SUPABASE_ANON_KEY=<von gwada.app/login oder .env.production>
